@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Planområde for planlegging igangsatt - innsynstjeneste - Objekttyper

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Objekttyper" {

  class Arealplan <<featureType>> {
    + objid [0..1] : Integer
    + nasjonalArealplanId [0..1] : NasjonalArealplanId
    + plannavn [0..1] : CharacterString
    + plantype [0..1] : CharacterString
    + kunngjøringsdatoVarselOmPlanoppstart [0..1] : Date
    + forslagsstillertype [0..1] : CharacterString
    + lovreferanse [0..1] : CharacterString
    + identifikasjon [0..1] : Identifikasjon
    + forsteDigitaliseringsdato [0..1] : DateTime
    + oppdateringsdato [0..1] : DateTime
    + link [0..1] : CharacterString
  }

  class "Planområde" as Planomr_de <<featureType>> {
    + objid [0..1] : Integer
    + identifikasjon [0..1] : Identifikasjon
    + arealplan [0..1] : Integer
    + førsteDigitaliseringsdato [0..1] : DateTime
    + nasjonalArealplanId [0..1] : NasjonalArealplanId
    + plannavn [0..1] : CharacterString
    + plantype [0..1] : CharacterString
    + kunngjøringsdatoVarselOmPlanoppstart [0..1] : Date
    + forslagsstillertype [0..1] : CharacterString
    + lovreferanse [0..1] : CharacterString
    + oppdateringsdato [0..1] : DateTime
    + link [0..1] : CharacterString

    ..Geometri..
    + geometry [1] : GM_Object
  }

  class NasjonalArealplanId <<dataType>> {
    + planid [0..1] : CharacterString
    + kommunenummer [0..1] : CharacterString
  }

  class Identifikasjon <<dataType>> {
    + lokalId [0..1] : CharacterString
    + navnerom [0..1] : CharacterString
    + versjonId [0..1] : CharacterString
  }

  class Plandokumenter {
  }
}

  Arealplan --> Planomr_de : planomrade [0..1]
  Arealplan --> Plandokumenter : plandokumenter [0..1]
  Planomr_de --> Arealplan : arealplan [0..1]
  Planomr_de --> Plandokumenter : plandokumenter [0..1]

@enduml
